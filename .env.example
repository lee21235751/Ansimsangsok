# 안심상속 환경변수 예시
# 현재 정적 배포 기준에서는 필수 환경변수가 없습니다.

# 안심상속 유료 상세자료 결제 연동 준비
# 실제 PG를 연결하기 전까지 PAYMENT_PROVIDER=mock 상태로 둡니다.
PAYMENT_PROVIDER=mock
PAYMENT_SUCCESS_URL=https://www.ansimsangsok.com/?payment=success
PAYMENT_FAIL_URL=https://www.ansimsangsok.com/?payment=fail
PAYMENT_CANCEL_URL=https://www.ansimsangsok.com/?payment=cancel

# Toss Payments 또는 PortOne 등 실제 PG 선택 후 아래 키를 채웁니다.
PAYMENT_CLIENT_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=

# 안심상속 결제수단 표시/활성화 준비
# 운영 계약/심사 후 실제 PG 관리자에서 결제수단을 활성화합니다.
PAYMENT_METHODS=card,kakao_pay,naver_pay
PAYMENT_PRIMARY_METHOD_LABEL=신용카드·카카오페이·네이버페이

# Toss Payments 통합결제창 최소 연동 준비
# 기본값은 mock입니다. 실제 결제창 활성화 전 운영 심사/키 설정을 확인합니다.
# PAYMENT_PROVIDER=toss
# PAYMENT_CLIENT_KEY=test_ck_...
# PAYMENT_SECRET_KEY=test_sk_...
