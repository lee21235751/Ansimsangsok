# 안심상속 환경변수 예시
# 실제 값은 Vercel Dashboard > Environment Variables 에서 설정하세요.

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LEADS_TABLE=leads

# Anthropic (유료 상세리포트 자동 생성)
ANTHROPIC_API_KEY=

# Resend (리드 알림 이메일)
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=
LEAD_NOTIFY_FROM=안심상속 <leads@send.ansimsangsok.kr>

# 결제 (현재 mock 모드. Toss 연동 시 변경)
PAYMENT_PROVIDER=mock
PAYMENT_SUCCESS_URL=https://www.ansimsangsok.kr/?payment=success
PAYMENT_FAIL_URL=https://www.ansimsangsok.kr/?payment=fail
PAYMENT_CANCEL_URL=https://www.ansimsangsok.kr/?payment=cancel
PAYMENT_CLIENT_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_METHODS=card,kakao_pay,naver_pay

# 관리자 API 토큰
ADMIN_LEAD_UPDATE_TOKEN=
